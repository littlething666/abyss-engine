{
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "NODE_ENV=production next build",
    "serve": "npx serve@14.2.5 out",
    "test:e2e": "node scripts/run-playwright.mjs --project=chromium-headful",
    "test:e2e:headful": "node scripts/run-playwright.mjs --project=chromium-headful",
    "test:e2e:headless": "node scripts/run-playwright.mjs --project=chromium-headless-ci",
    "test:e2e:smoke": "node scripts/run-playwright.mjs tests/boot.spec.ts --project=chromium-headless-ci",
    "test:e2e:ci": "node scripts/run-playwright.mjs --project=chromium-headless-ci --retries=2",
    "test:e2e:install": "npx playwright install --with-deps",
    "test:e2e:prepare": "npm run test:e2e:install",
    "test:e2e:ui": "node scripts/run-playwright.mjs --project=chromium-headful --ui",
    "test:unit": "vitest",
    "test:unit:run": "vitest run",
    "test:unit:coverage": "vitest run --coverage",
    "check:unused": "npx knip",
    "knip": "knip"
