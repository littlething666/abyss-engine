{
  "name": "abyss-durable-orchestrator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "d1:init:local": "wrangler d1 execute abyss-generation-state --local --file ./d1/init.sql",
    "d1:reset:local": "wrangler d1 execute abyss-generation-state --local --file ./d1/reset.sql",
    "d1:init:remote": "wrangler d1 execute abyss-generation-state --remote --file ./d1/init.sql",
    "d1:reset:remote": "wrangler d1 execute abyss-generation-state --remote --file ./d1/reset.sql",
    "generate:types": "wrangler types ./worker-configuration.d.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:runtime": "vitest run --config vitest.runtime.config.ts",
    "test:watch": "vitest"
  },
  "dependencies": {
    "hono": "^4.12.18",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.3",
    "@cloudflare/workers-types": "^4.20260508.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "wrangler": "^4.90.0"
  }
}
